rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /povs/{povId} {
      // Anyone can read published PoVs (public feed).
      allow read: if true;
      // Any signed-in user can create a PoV.
      allow create: if request.auth != null;
      // Only the author can update or delete their own PoV.
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.author;
    }

    match /users/{userId} {
      // Profiles are publicly readable.
      allow read: if true;
      // A user can only write their own profile document.
      allow write: if request.auth != null
        && request.auth.uid == userId;
    }

  }
}